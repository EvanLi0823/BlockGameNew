  "references": {
    "batch-modification": "references/constraints/batch-modification.md",
    "api-verification": "references/constraints/api-verification.md",
    "method-signature": "references/constraints/method-signature.md",
    "using-statements": "references/constraints/using-statements.md",
    "code-blocks": "references/constraints/code-blocks.md",
    "namespaces": "references/constraints/namespaces.md",
    "code-quality": "references/csharp/code-quality.md",
    "code-style": "references/csharp/code-style.md",
    "singleton-pattern": "references/unity/singleton-pattern.md",
